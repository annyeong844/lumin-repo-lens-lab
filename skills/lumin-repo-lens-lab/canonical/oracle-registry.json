{
  "schemaVersion": "oracle-registry.v1",
  "policyVersion": "evidence-ladder.v1",
  "artifactRequirements": {
    "registryContentHash": "required",
    "analysisInputSetHash": "required-for-semantic-cache-or-clean-claims"
  },
  "refutationPolicy": {
    "default": "semantic-silence-refutes-nothing",
    "rule": "A higher-tier oracle may refute a lower-tier candidate only when this registry lists an explicit refutesCandidateKinds entry for the candidate kind and scope relation."
  },
  "confidenceTiers": {
    "verified": {
      "claimPermission": "May make bounded factual claims inside the oracle authority.",
      "requiresCoverage": "ran",
      "staleBehavior": "downgrade-to-coverage-gap"
    },
    "rule-backed": {
      "claimPermission": "May report deterministic rule evidence with rule class and provenance.",
      "requiresCoverage": "ran",
      "staleBehavior": "downgrade-to-coverage-gap"
    },
    "candidate": {
      "claimPermission": "May ask review questions. Must not assert semantic truth.",
      "requiresCoverage": "ran",
      "staleBehavior": "downgrade-to-coverage-gap"
    }
  },
  "coverageStatuses": {
    "ran": {
      "mayRepresentClean": true,
      "description": "The oracle completed over the declared scope. Clean is scoped to this oracle, this authority, and this analysis input set."
    },
    "not-run": {
      "mayRepresentClean": false,
      "description": "The oracle was not requested for this scope."
    },
    "unavailable": {
      "mayRepresentClean": false,
      "description": "The oracle is supported, but could not complete because of environment, toolchain, dependency, configuration, or build conditions."
    },
    "unsupported": {
      "mayRepresentClean": false,
      "description": "The oracle does not support this language surface or analysis target."
    }
  },
  "sourceKinds": {
    "syntax": "Parser-owned structural evidence.",
    "syntax-heuristic": "Parser or heuristic evidence that proposes review candidates.",
    "semantic-oracle": "Language-owned semantic evidence.",
    "rule-engine": "Rule-owned evidence that is not promoted to compiler truth."
  },
  "oracles": [
