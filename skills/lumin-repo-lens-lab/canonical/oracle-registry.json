    {
      "id": "rust.cargo-check",
      "language": "rust",
      "sourceKind": "semantic-oracle",
      "confidence": "verified",
      "authorityIds": [
        "rust.rustc.error-diagnostic",
        "rust.rustc.type-diagnostic",
        "rust.rustc.borrow-diagnostic",
        "rust.rustc.name-resolution-diagnostic",
        "rust.rustc.cfg-expanded-diagnostic",
        "rust.rustc.codeless-error-diagnostic"
      ],
      "claimKinds": [
        "verified.rust.rustc-error-diagnostic",
        "verified.rust.rustc-codeless-error-diagnostic",
        "rule-backed.rust.rustc-lint-diagnostic",
        "candidate.rust.unclassified-cargo-diagnostic"
      ],
      "reservedClaimKinds": [
        "verified.rust.type-diagnostic",
        "verified.rust.borrow-diagnostic",
        "verified.rust.name-resolution-diagnostic",
        "verified.rust.cfg-expanded-diagnostic"
      ],
      "candidateKinds": [],
      "refutesCandidateKinds": [],
      "authority": [
        "rustc type diagnostics",
        "rustc borrow diagnostics",
        "rustc name-resolution diagnostics",
        "cfg-expanded crate diagnostics for analyzed targets"
      ],
      "notAuthority": [
        "unsafe soundness proof",
        "FFI contract proof",
        "cfg-disabled code",
        "style or convention linting",
        "semantic confirmation of syntax candidates outside emitted diagnostics"
      ],
      "coverageScope": "crate-target-configuration",
      "coverageDimensions": [
        "package",
        "target",
        "feature set",
        "target triple",
        "cfg set",
        "profile",
        "cargo and rustc versions"
      ],
      "normalizedDiagnosticSchema": {
        "codeNamespace": [
          "rustc-codeless",
          "rustc-error",
          "rustc-non-ecode",
          "unknown"
        ],
        "codeNamespaceDerivation": [
          {
            "when": "message.code === null",
            "codeNamespace": "rustc-codeless",
            "codeKind": "null-error-code"
          },
          {
            "when": "message.code.code matches ^E[0-9]+$",
            "codeNamespace": "rustc-error",
            "codeKind": "rustc-error-code"
          },
          {
            "when": "message.code.code is any other non-empty string",
            "codeNamespace": "rustc-non-ecode",
            "codeKind": "non-ecode-name"
          },
          {
            "when": "message.code is missing or malformed",
            "codeNamespace": "unknown",
            "codeKind": "unknown"
          }
        ],
        "primarySpan": [
          "user-code",
          "dependency",
          "generated",
          "unknown"
        ]
      },
      "diagnosticClassification": [
        {
          "when": {
            "messageFormat": "cargo-json",
            "reason": "compiler-message",
            "levelNotIn": [
              "error",
              "warning"
            ]
          },
          "disposition": "non-finding",
          "rule": "note-help-failure-note-are-not-findings",
          "notes": "Cargo may emit note, help, and failure-note compiler-message entries as top-level events. They are attached context, not user-facing findings."
        },
        {
          "when": {
            "messageFormat": "cargo-json",
            "reason": "compiler-message",
            "primarySpan": "not-user-code",
            "level": "error"
          },
          "disposition": "coverage-unavailable",
          "rule": "non-user-primary-error-makes-absence-clean-unavailable",
          "notes": "Dependency, generated, target, or unknown primary error diagnostics are not user-facing findings and prevent absence-clean claims for the selected user scope."
        },
        {
          "when": {
            "messageFormat": "cargo-json",
            "reason": "compiler-message",
            "primarySpan": "not-user-code"
          },
          "disposition": "non-finding",
          "rule": "non-user-primary-diagnostics-are-not-user-facing-findings"
        },
        {
          "when": {
            "messageFormat": "cargo-json",
            "reason": "compiler-message",
            "primarySpan": "user-code",
            "codeNamespace": "rustc-non-ecode"
          },
          "confidence": "rule-backed",
          "claimKind": "rule-backed.rust.rustc-lint-diagnostic",
          "rule": "non-ecode-code-name-treated-as-rule-backed-before-level",
          "notes": "Denied lints may arrive as level:error. Non-E-code rustc diagnostics are rule-backed before level classification."
        },
        {
          "when": {
            "messageFormat": "cargo-json",
            "reason": "compiler-message",
            "level": "error",
            "primarySpan": "user-code",
            "codeNamespace": "rustc-error"
          },
          "confidence": "verified",
          "authorityId": "rust.rustc.error-diagnostic",
          "claimKind": "verified.rust.rustc-error-diagnostic",
          "rule": "ecode-error-user-code-primary",
          "notes": "M7 keeps rustc error diagnostics generic until code-family mapping is explicitly reviewed."
        },
        {
          "when": {
            "messageFormat": "cargo-json",
            "reason": "compiler-message",
            "level": "error",
            "primarySpan": "user-code",
            "codeNamespace": "rustc-codeless"
          },
          "confidence": "verified",
          "authorityId": "rust.rustc.codeless-error-diagnostic",
          "claimKind": "verified.rust.rustc-codeless-error-diagnostic",
          "rule": "codeless-error-user-code-primary",
          "notes": "Codeless rustc errors are verified only with a user-code primary span. Summary, note, help, and failure-note messages are not findings."
        },
        {
          "when": {
            "messageFormat": "cargo-json",
            "reason": "compiler-message",
            "levelIn": [
              "error",
              "warning"
            ],
            "primarySpan": "user-code"
          },
          "confidence": "candidate",
          "claimKind": "candidate.rust.unclassified-cargo-diagnostic",
          "rule": "fallback-real-warning-or-error-never-verified",
          "notes": "Only remaining real user-code error or warning diagnostics may fall back to candidate. Non-finding messages are not promoted."
        }
      ],
      "coverageKinds": [
        {
          "coverageKind": "cargo-event-stream",
          "meaning": "cargo JSON event stream was captured and parsed"
        },
        {
          "coverageKind": "absence-clean",
          "cleanKind": "verified-rustc-error-absence",
          "absenceOfClaimKinds": [
            "verified.rust.rustc-error-diagnostic",
            "verified.rust.rustc-codeless-error-diagnostic"
          ],
          "allowsConcurrentClaimKinds": [
            "rule-backed.rust.rustc-lint-diagnostic",
            "candidate.rust.unclassified-cargo-diagnostic"
          ]
        }
      ],
      "completionSignal": {
        "requiredForClean": [
          "cargo-json streamParseStatus complete",
          "cargo-json invalidJsonLineCount 0",
          "cargo-json build-finished event present",
          "cargo-json build-finished success true"
        ],
        "emptyDiagnosticStreamIsClean": false
      },
      "userCodePrimarySpanDefinition": "Primary span resolved to a workspace member source file, excluding target and OUT_DIR generated files. Macro expansion chains resolve to the nearest user-written span; if no user-written span is available, the diagnostic is not user-code-primary for verified classification.",
      "cacheReusePolicy": {
        "default": "reuse-only-when-analysisInputSetHash-complete",
        "buildScriptOrProcMacroInfluence": "no-reuse-unless-complete-influence-set-is-captured",
        "fallback": "rerun-or-mark-coverage-unavailable"
      },
      "analysisInputSet": [
        "local package Rust source bytes",
        "Cargo.toml files",
        "Cargo.lock",
        "rust-toolchain files",
        "selected package",
        "selected target",
        "selected feature flags",
        "target triple",
        "cfg set",
        "profile",
        "rustc version",
        "cargo version",
        "relevant cargo config",
        "environment variables that affect compilation",
        "build script and proc-macro influence set"
      ],
      "versionPolicy": "rustc-and-cargo-version-recorded",
      "status": "proposed-m7",
      "notes": "Consumes cargo/rustc JSON diagnostics. User-code primary error diagnostics may be verified findings even when target-wide absence coverage is unavailable. Rustc lint diagnostics from the same stream are rule-backed, not verified."
    },
